    "command": "uv",
    "args": [
      "run",
      "dqa-mcp"
    ],
    "env": {
      "DQA_MCP_SERVER_TRANSPORT": "stdio"
    }
  },
  "frankfurter": {
    "transport": "stdio",
    "command": "uv",
